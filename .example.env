# X Bookmarked Posts Organizer — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env or .env.local — both are gitignored.

# ── X API Credentials (required for xbm sync) ──────────────────────────────
# Create an app at https://developer.twitter.com/en/portal/dashboard
# Enable OAuth 2.0 and add http://localhost:8080/callback as a redirect URI.
X_CLIENT_ID=your_x_client_id_here
X_CLIENT_SECRET=your_x_client_secret_here

# ── Netlify Deployment (required for xbm export-static + netlify deploy) ────
# Create a personal access token at:
# https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token_here

# ── Optional overrides (defaults shown) ─────────────────────────────────────
# X_TOKEN_PATH=data/tokens.json
# X_DATABASE_PATH=data/bookmarks.db
