# X API Credentials (required)
# Get these from https://developer.twitter.com/en/portal/dashboard
X_CLIENT_ID=your_client_id_here
X_CLIENT_SECRET=your_client_secret_here

# Optional: OAuth tokens (loaded from data/tokens.json after first auth)
# X_ACCESS_TOKEN=
# X_REFRESH_TOKEN=

# Optional: Custom paths (defaults shown)
# X_TOKEN_PATH=data/tokens.json
# X_DATABASE_PATH=data/bookmarks.db